    { "text": "기     간 :", "x": 270, "y": 1450, "font_key": "label" },
    { "text": "이수시간 :", "x": 270, "y": 1545, "font_key": "label" },
    { "text": "4시간", "x": 580, "y": 1545, "font_key": "value" },
    { "text": "진행강사 :", "x": 270, "y": 1640, "font_key": "label" },
    { "text": "이인수 (한국상담학회 1급 전문영역 수련감독자 194)", "x": 580, "y": 1640, "font_key": "value" }
  ],
  "dynamic_fields": {
    "발급번호": {
